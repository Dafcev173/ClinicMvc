@model IEnumerable<Patient>
@{
    ViewData["Title"] = "Пациенти";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Пациенти</h2>
    <button class="btn btn-primary" onclick="openCreateModal()">+ Нов пациент</button>
</div>

<table class="table table-bordered table-hover" id="patientsTable">
    <thead class="table-dark">
        <tr>
            <th>Ime</th>
            <th>Презиме</th>
            <th>ЕМБГ</th>
            <th>Телефон</th>
            <th>Е-пошта</th>
            <th>Акции</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr id="patient-row-@p.Id">
                <td>@p.FirstName</td>
                <td>@p.LastName</td>
                <td>@p.Embg</td>
                <td>@p.Phone</td>
                <td>@p.Email</td>
                <td>
                    <button class="btn btn-sm btn-warning" onclick="openEditModal(@p.Id)">Измени</button>
                    <button class="btn btn-sm btn-danger" onclick="deletePatient(@p.Id, '@p.FirstName @p.LastName')">Избриши</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@* ── Модал: Нов / Измени пациент ── *@
<div class="modal fade" id="patientModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="patientModalTitle">Нов пациент</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="patientForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="patientId" name="Id" value="0" />

                    <div class="mb-3">
                        <label class="form-label">Ime <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="firstName" name="FirstName" required />
                        <div class="invalid-feedback">Името е задолжително.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Презиме <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="lastName" name="LastName" required />
                        <div class="invalid-feedback">Презимето е задолжително.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">ЕМБГ <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="embg" name="Embg"
                               maxlength="13" placeholder="13 цифри" required />
                        <div class="invalid-feedback">ЕМБГ е задолжителен (13 цифри).</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Телефон</label>
                        <input type="text" class="form-control" id="phone" name="Phone" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Е-пошта</label>
                        <input type="email" class="form-control" id="email" name="Email"
                               placeholder="primer@mail.com" />
                        <div class="invalid-feedback">Внесете валидна е-пошта.</div>
                    </div>

                    <div id="patientFormErrors" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-primary" onclick="savePatient()">Зачувај</button>
            </div>
        </div>
    </div>
</div>

@* ── Модал: Потврда за бришење ── *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Избриши</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Дали сте сигурни дека сакате да го/ја избришете <strong id="deleteTargetName"></strong>?</p>
                <form id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deletePatientId" name="id" value="0" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Избриши</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const patientModal = new bootstrap.Modal(document.getElementById('patientModal'));
const deleteModal  = new bootstrap.Modal(document.getElementById('deleteModal'));

function openCreateModal() {
    document.getElementById('patientModalTitle').textContent = 'Нов пациент';
    document.getElementById('patientId').value = '0';
    document.getElementById('firstName').value = '';
    document.getElementById('lastName').value  = '';
    document.getElementById('embg').value      = '';
    document.getElementById('phone').value     = '';
    document.getElementById('email').value     = '';
    document.getElementById('patientFormErrors').classList.add('d-none');
    patientModal.show();
}

function openEditModal(id) {
    $.get(`/Patients/GetById/${id}`, function(p) {
        document.getElementById('patientModalTitle').textContent = 'Измени пациент';
        document.getElementById('patientId').value = p.id;
        document.getElementById('firstName').value = p.firstName;
        document.getElementById('lastName').value  = p.lastName;
        document.getElementById('embg').value      = p.embg;
        document.getElementById('phone').value     = p.phone  || '';
        document.getElementById('email').value     = p.email  || '';
        document.getElementById('patientFormErrors').classList.add('d-none');
        patientModal.show();
    });
}

function savePatient() {
    const id  = document.getElementById('patientId').value;
    const url = id === '0' ? '/Patients/Create' : '/Patients/Edit';
    const token = document.querySelector('#patientForm input[name="__RequestVerificationToken"]').value;

    // Client-side: EMBG must be exactly 13 digits
    const embg = document.getElementById('embg').value.trim();
    if (!/^\d{13}$/.test(embg)) {
        const errDiv = document.getElementById('patientFormErrors');
        errDiv.textContent = 'ЕМБГ мора да содржи точно 13 цифри.';
        errDiv.classList.remove('d-none');
        return;
    }

    const data = {
        Id:        id,
        FirstName: document.getElementById('firstName').value,
        LastName:  document.getElementById('lastName').value,
        Embg:      embg,
        Phone:     document.getElementById('phone').value,
        Email:     document.getElementById('email').value,
        __RequestVerificationToken: token
    };

    $.post(url, data)
        .done(function() {
            patientModal.hide();
            location.reload();
        })
        .fail(function(xhr) {
            const errDiv = document.getElementById('patientFormErrors');
            const response = xhr.responseJSON;
            errDiv.innerHTML = response?.errors?.join('<br>') || 'Грешка при зачувување.';
            errDiv.classList.remove('d-none');
        });
}

function deletePatient(id, name) {
    document.getElementById('deletePatientId').value  = id;
    document.getElementById('deleteTargetName').textContent = name;
    deleteModal.show();
}

function confirmDelete() {
    const id    = document.getElementById('deletePatientId').value;
    const token = document.querySelector('#deleteForm input[name="__RequestVerificationToken"]').value;

    $.post('/Patients/Delete', { id: id, __RequestVerificationToken: token })
        .done(function() {
            deleteModal.hide();
            $(`#patient-row-${id}`).fadeOut(300, function() { $(this).remove(); });
        })
        .fail(function() {
            alert('Грешка при бришење. Можно е пациентот да има поврзани термини.');
        });
}
</script>
}

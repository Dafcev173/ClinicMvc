@* Dashboard за најавен доктор - гледа само свои податоци *@
@model Doctor
@{
    ViewData["Title"] = "Мој Dashboard";
    var schedule = (IEnumerable<Appointment>)ViewBag.TodaySchedule;
}

<div class="mb-4">
    <h2>Добредојдовте, д-р @Model.LastName</h2>
    <p class="text-muted">@Model.Specialty · @DateTime.Today.ToString("dd.MM.yyyy")</p>
</div>

<div class="card">
    <div class="card-header bg-dark text-white">Денешен распоред</div>
    <div class="card-body">
        @if (!schedule.Any())
        {
            <p class="text-muted">Нема закажани термини за денес.</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr><th>Време</th><th>Пациент</th><th>Статус</th></tr>
                </thead>
                <tbody>
                    @foreach (var a in schedule)
                    {
                        <tr>
                            <td>@a.AppointmentTime.ToString(@"hh\:mm")</td>
                            <td>@a.PatientName</td>
                            <td><span class="badge bg-info text-dark">@a.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

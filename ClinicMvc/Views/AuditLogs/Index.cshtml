@* Листа на сите CRUD активности - CREATE | Doctor | admin *@
@model IEnumerable<AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<h2 class="mb-3">Логови на активности</h2>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Датум/Време</th>
            <th>Акција</th>
            <th>Ентитет</th>
            <th>ID</th>
            <th>Корисник</th>
            <th>Опис</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            var badgeClass = log.ActionType switch
            {
                "CREATE" => "bg-success",
                "UPDATE" => "bg-warning text-dark",
                "DELETE" => "bg-danger",
                _        => "bg-secondary"
            };
            <tr>
                <td>@log.LogDateTime.ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td><span class="badge @badgeClass">@log.ActionType</span></td>
                <td>@log.EntityName</td>
                <td>@log.EntityId</td>
                <td>@log.Username</td>
                <td>@log.Description</td>
            </tr>
        }
    </tbody>
</table>

@{
    var pagination = (PaginationInfo)ViewBag.Pagination;
    var isFirstPage = pagination.CurrentPage <= 1;
    var isLastPage  = pagination.CurrentPage >= pagination.TotalPages;
}

<nav class="d-flex justify-content-between align-items-center mt-3">
    @if (isFirstPage)
    {
        <span class="btn btn-outline-secondary btn-sm disabled">Претходна</span>
    }
    else
    {
        <a asp-action="Index" asp-route-page="@(pagination.CurrentPage - 1)" class="btn btn-outline-secondary btn-sm">Претходна</a>
    }

    <span class="text-muted">
        Страна @pagination.CurrentPage од @pagination.TotalPages (@pagination.TotalCount вкупно)
    </span>

    @if (isLastPage)
    {
        <span class="btn btn-outline-secondary btn-sm disabled">Следна</span>
    }
    else
    {
        <a asp-action="Index" asp-route-page="@(pagination.CurrentPage + 1)" class="btn btn-outline-secondary btn-sm">Следна</a>
    }
</nav>

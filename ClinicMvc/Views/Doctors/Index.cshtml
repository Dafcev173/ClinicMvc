@* Листа на доктори - Ime, Презиме, Специјалност, Акции *@
@model IEnumerable<Doctor>
@{
    ViewData["Title"] = "Доктори";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Доктори</h2>
    <button class="btn btn-primary" onclick="openCreateModal()">+ Нов доктор</button>
</div>

<table class="table table-bordered table-hover" id="doctorsTable">
    <thead class="table-dark">
        <tr>
            <th>Ime</th>
            <th>Презиме</th>
            <th>Специјалност</th>
            <th>Телефон</th>
            <th>Активен</th>
            <th>Акции</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr id="doctor-row-@d.Id">
                <td>@d.FirstName</td>
                <td>@d.LastName</td>
                <td>@d.Specialty</td>
                <td>@d.Phone</td>
                <td>
                    @if (d.IsActive) { <span class="badge bg-success">Да</span> }
                    else { <span class="badge bg-secondary">Не</span> }
                </td>
                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@d.Id">Детали</a>
                    <button class="btn btn-sm btn-warning" onclick="openEditModal(@d.Id)">Измени</button>
                    <button class="btn btn-sm btn-danger" onclick="deleteDoctor(@d.Id, '@d.FirstName @d.LastName')">Избриши</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Модал за креирање и измена на доктор *@
<div class="modal fade" id="doctorModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="doctorModalTitle">Нов доктор</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="doctorForm" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="doctorId" name="Id" value="0" />
                    <div class="mb-3">
                        <label class="form-label">Ime <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="firstName" name="FirstName" />
                        <div class="invalid-feedback">Името е задолжително.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Презиме <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="lastName" name="LastName" />
                        <div class="invalid-feedback">Презимето е задолжително.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Специјалност</label>
                        <input type="text" class="form-control" id="specialty" name="Specialty" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Телефон</label>
                        <input type="text" class="form-control" id="phone" name="Phone" />
                        <div class="invalid-feedback">Телефонот смее да содржи само цифри и + знак.</div>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="isActive" name="IsActive" value="true" checked />
                        <label class="form-check-label" for="isActive">Активен</label>
                    </div>

                    @* Полиња за кориснички акредитиви - видливи САМО при креирање нов доктор.
                       При измена на постоечки доктор, JS ги крие (акредитивите не се менуваат тука). *@
                    <hr id="credentialsDivider" />
                    <div id="credentialsSection">
                        <h6 class="text-muted mb-3">Кориснички акредитиви за најава</h6>

                        <div class="mb-3">
                            <label class="form-label">Корисничко ime <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="username" name="Username" autocomplete="off" />
                            <div class="invalid-feedback">Корисничкото ime е задолжително (мин. 3 карактери).</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Лозинка <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="password" name="Password" autocomplete="new-password" />
                            <div class="invalid-feedback">Лозинката мора да има најмалку 6 карактери.</div>
                        </div>
                    </div>

                    <div id="doctorFormErrors" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-primary" onclick="saveDoctor()">Зачувај</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Избриши</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Дали сте сигурни дека сакате да го избришете <strong id="deleteTargetName"></strong>?</p>
                <form id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteDoctorId" name="id" value="0" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Избриши</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const doctorModal = new bootstrap.Modal(document.getElementById('doctorModal'));
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

    function openCreateModal() {
        document.getElementById('doctorModalTitle').textContent = 'Нов доктор';
        document.getElementById('doctorId').value    = '0';
        document.getElementById('firstName').value  = '';
        document.getElementById('lastName').value   = '';
        document.getElementById('specialty').value  = '';
        document.getElementById('phone').value      = '';
        document.getElementById('isActive').checked = true;
        document.getElementById('username').value   = '';
        document.getElementById('password').value   = '';

        // Кориснички акредитиви се внесуваат САМО при креирање нов доктор
        document.getElementById('credentialsSection').classList.remove('d-none');
        document.getElementById('credentialsDivider').classList.remove('d-none');

        clearValidation();
        doctorModal.show();
    }

    function openEditModal(id) {
        $.get(`/Doctors/GetById/${id}`, function(doc) {
            document.getElementById('doctorModalTitle').textContent = 'Измени доктор';
            document.getElementById('doctorId').value    = doc.id;
            document.getElementById('firstName').value  = doc.firstName;
            document.getElementById('lastName').value   = doc.lastName;
            document.getElementById('specialty').value  = doc.specialty || '';
            document.getElementById('phone').value      = doc.phone || '';
            document.getElementById('isActive').checked = doc.isActive;

            // При измена не бараме нови акредитиви - ги криеме тие полиња
            document.getElementById('credentialsSection').classList.add('d-none');
            document.getElementById('credentialsDivider').classList.add('d-none');

            clearValidation();
            doctorModal.show();
        });
    }

    function validateDoctorForm() {
        let isValid = true;
        const isCreating = document.getElementById('doctorId').value === '0';

        const firstName = document.getElementById('firstName');
        if (!firstName.value.trim()) { firstName.classList.add('is-invalid'); isValid = false; }
        else { firstName.classList.remove('is-invalid'); firstName.classList.add('is-valid'); }

        const lastName = document.getElementById('lastName');
        if (!lastName.value.trim()) { lastName.classList.add('is-invalid'); isValid = false; }
        else { lastName.classList.remove('is-invalid'); lastName.classList.add('is-valid'); }

        const phone = document.getElementById('phone');
        if (phone.value.trim() && !/^[0-9+\s\-]+$/.test(phone.value.trim())) {
            phone.classList.add('is-invalid'); isValid = false;
        } else {
            phone.classList.remove('is-invalid');
            if (phone.value.trim()) phone.classList.add('is-valid');
        }

        // Username/Password се проверуваат само при креирање (полињата се скриени при измена)
        if (isCreating) {
            const username = document.getElementById('username');
            if (username.value.trim().length < 3) { username.classList.add('is-invalid'); isValid = false; }
            else { username.classList.remove('is-invalid'); username.classList.add('is-valid'); }

            const password = document.getElementById('password');
            if (password.value.length < 6) { password.classList.add('is-invalid'); isValid = false; }
            else { password.classList.remove('is-invalid'); password.classList.add('is-valid'); }
        }

        return isValid;
    }

    function clearValidation() {
        document.getElementById('doctorFormErrors').classList.add('d-none');
        ['firstName', 'lastName', 'specialty', 'phone', 'username', 'password'].forEach(id => {
            document.getElementById(id).classList.remove('is-invalid', 'is-valid');
        });
    }

    function saveDoctor() {
        if (!validateDoctorForm()) return;
        const id    = document.getElementById('doctorId').value;
        const isCreating = id === '0';
        const url   = isCreating ? '/Doctors/Create' : '/Doctors/Edit';
        const token = document.querySelector('#doctorForm input[name="__RequestVerificationToken"]').value;

        const data = {
            Id: id,
            FirstName: document.getElementById('firstName').value.trim(),
            LastName:  document.getElementById('lastName').value.trim(),
            Specialty: document.getElementById('specialty').value.trim(),
            Phone:     document.getElementById('phone').value.trim(),
            IsActive:  document.getElementById('isActive').checked,
            __RequestVerificationToken: token
        };

        // Username/Password се додаваат во податоците САМО при креирање -
        // DoctorCreateViewModel на серверот ги очекува само тогаш (Edit прима обичен Doctor модел)
        if (isCreating) {
            data.Username = document.getElementById('username').value.trim();
            data.Password = document.getElementById('password').value;
        }

        $.post(url, data)
            .done(function() { doctorModal.hide(); location.reload(); })
            .fail(function(xhr) {
                const errDiv = document.getElementById('doctorFormErrors');
                errDiv.innerHTML = xhr.responseJSON?.errors?.join('<br>') || 'Грешка при зачувување.';
                errDiv.classList.remove('d-none');
            });
    }

    function deleteDoctor(id, name) {
        document.getElementById('deleteDoctorId').value = id;
        document.getElementById('deleteTargetName').textContent = name;
        deleteModal.show();
    }

    function confirmDelete() {
        const id    = document.getElementById('deleteDoctorId').value;
        const token = document.querySelector('#deleteForm input[name="__RequestVerificationToken"]').value;

        $.post('/Doctors/Delete', { id: id, __RequestVerificationToken: token })
            .done(function() {
                deleteModal.hide();
                $(`#doctor-row-${id}`).fadeOut(300, function() { $(this).remove(); });
            })
            .fail(function() { alert('Грешка при бришење.'); });
    }
</script>
}

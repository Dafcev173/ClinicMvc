@model IEnumerable<Doctor>
@{
    ViewData["Title"] = "Доктори";
}

<h1>Доктори</h1>

<p><a asp-action="Create" class="btn">+ Нов доктор</a></p>

<table>
    <thead>
        <tr>
            <th>Име</th>
            <th>Презиме</th>
            <th>Специјалност</th>
            <th>Телефон</th>
            <th>Активен</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var doctor in Model)
        {
            <tr>
                <td>@doctor.FirstName</td>
                <td>@doctor.LastName</td>
                <td>@doctor.Specialty</td>
                <td>@doctor.Phone</td>
                <td>@(doctor.IsActive ? "Да" : "Не")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@doctor.Id">Измени</a> |
                    <a asp-action="Delete" asp-route-id="@doctor.Id">Избриши</a>
                </td>
            </tr>
        }
    </tbody>
</table>

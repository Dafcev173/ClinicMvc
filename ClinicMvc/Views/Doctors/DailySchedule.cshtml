@* Дневен распоред на доктор - избран датум, не само денес *@
@model IEnumerable<Appointment>
@{
    ViewData["Title"] = "Дневен распоред";
    var doctor = (Doctor)ViewBag.Doctor;
    var selectedDate = (DateTime)ViewBag.SelectedDate;
}

<h2>Дневен распоред - Д-р @doctor.FirstName @doctor.LastName</h2>
<p class="text-muted">@doctor.Specialty</p>

<form method="get" class="d-flex align-items-end gap-2 mb-3">
    <div>
        <label class="form-label">Датум</label>
        <input type="date" name="date" class="form-control" value="@selectedDate.ToString("yyyy-MM-dd")" />
    </div>
    <button type="submit" class="btn btn-secondary">Прикажи</button>
</form>

<div class="card">
    <div class="card-header bg-dark text-white">
        Распоред за @selectedDate.ToString("dd.MM.yyyy")
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <p class="text-muted p-3 mb-0">Нема закажани термини за избраниот датум.</p>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Време</th>
                        <th>Пациент</th>
                        <th>Статус</th>
                        <th>Белешки</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td>@a.AppointmentTime.ToString(@"hh\:mm")</td>
                            <td>@a.PatientName</td>
                            <td><span class="badge bg-secondary">@a.Status</span></td>
                            <td>@(string.IsNullOrEmpty(a.Notes) ? "-" : a.Notes)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<a asp-action="Details" asp-route-id="@doctor.Id" class="btn btn-secondary mt-3">Назад</a>

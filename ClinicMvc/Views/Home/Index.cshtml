@* Почетна страница - hero секција + брз пристап зависно од улогата на најавениот корисник *@
@{
    ViewData["Title"] = "Почетна";
}

<div class="hero-banner mb-5">
    <div class="container-fluid">
        <h1 class="display-5 fw-bold mb-2">Clinic Management System</h1>
        <p class="fs-5 mb-3 text-white-50">
            Систем за управување со доктори, пациенти и термини во приватна специјалистичка ординација.
        </p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="d-inline-flex align-items-center gap-2 bg-white bg-opacity-10 rounded-pill px-3 py-2">
                <i class="bi bi-person-circle fs-5"></i>
                <span>
                    Најавени сте како <strong>@User.Identity!.Name</strong>
                </span>
                <span class="badge bg-light text-dark ms-1">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
            </div>
        }
    </div>
</div>

@if (User.IsInRole("Administrator"))
{
    <h5 class="text-uppercase text-muted mb-3 fw-semibold small">Брз пристап</h5>
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <a asp-controller="Doctors" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <h5 class="mt-3 mb-1">Доктори</h5>
                <p class="text-muted small mb-0">Управување со доктори и специјалности</p>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-controller="Patients" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-people"></i>
                </div>
                <h5 class="mt-3 mb-1">Пациенти</h5>
                <p class="text-muted small mb-0">Регистар на пациенти и медицинска историја</p>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-controller="Appointments" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <h5 class="mt-3 mb-1">Термини</h5>
                <p class="text-muted small mb-0">Закажување, филтри, статистика</p>
            </a>
        </div>
        <div class="col-md-3 col-sm-6">
            <a asp-controller="AuditLogs" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-secondary bg-opacity-10 text-secondary">
                    <i class="bi bi-clipboard-data"></i>
                </div>
                <h5 class="mt-3 mb-1">Логови</h5>
                <p class="text-muted small mb-0">Преглед на сите CRUD активности</p>
            </a>
        </div>
    </div>

    <h5 class="text-uppercase text-muted mb-3 fw-semibold small">Администрација</h5>
    <div class="row g-3">
        <div class="col-md-3 col-sm-6">
            <a asp-controller="Users" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-person-badge"></i>
                </div>
                <h5 class="mt-3 mb-1">Корисници</h5>
                <p class="text-muted small mb-0">Кориснички сметки и лозинки</p>
            </a>
        </div>
    </div>
}
else if (User.IsInRole("Doctor"))
{
    <h5 class="text-uppercase text-muted mb-3 fw-semibold small">Брз пристап</h5>
    <div class="row g-3">
        <div class="col-md-4">
            <a asp-controller="DoctorDashboard" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-speedometer2"></i>
                </div>
                <h5 class="mt-3 mb-1">Мој Dashboard</h5>
                <p class="text-muted small mb-0">Денешен распоред и преглед</p>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Appointments" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-calendar-check"></i>
                </div>
                <h5 class="mt-3 mb-1">Мои термини</h5>
                <p class="text-muted small mb-0">Закажани, во тек и завршени прегледи</p>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Patients" asp-action="Index" class="quick-link-card">
                <div class="quick-link-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-people"></i>
                </div>
                <h5 class="mt-3 mb-1">Пациенти</h5>
                <p class="text-muted small mb-0">Преглед на пациенти и историја</p>
            </a>
        </div>
    </div>
}

@* Модел кој содржи филтри и dropdown опции за dashboard страницата *@
@model AppointmentIndexViewModel
@{
    ViewData["Title"] = "Термини";
}

@* Наслов и копче за додавање нов термин *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Термини</h2>
    <button class="btn btn-primary" onclick="openCreateModal()">+ Нов термин</button>
</div>

@* ══════════════════ Dashboard приказ - два столба ══════════════════ *@
<div class="row">

    @* ─────────── Лева страна (col-md-3): Статистика + Филтри ─────────── *@
    <div class="col-md-3">

        @* Контејнер за статистика - се вчитува и освежува преку AJAX *@
        <div id="statsContainer">
            <div class="text-center py-3">
                <div class="spinner-border spinner-border-sm text-primary"></div>
            </div>
        </div>

        @* Картичка со филтри за пребарување *@
        <div class="card card-body">
            <h6 class="mb-3">🔍 Филтри</h6>

            <div class="mb-2">
                <label class="form-label small">Ime на пациент</label>
                <input type="text" id="filterPatientFirstName" class="form-control form-control-sm"
                       placeholder="пр. Ана" />
            </div>

            <div class="mb-2">
                <label class="form-label small">Презиме на пациент</label>
                <input type="text" id="filterPatientLastName" class="form-control form-control-sm"
                       placeholder="пр. Стојанова" />
            </div>

            <div class="mb-2">
                <label class="form-label small">ЕМБГ на пациент</label>
                <input type="text" id="filterPatientEmbg" class="form-control form-control-sm"
                       placeholder="пр. 12034567" />
            </div>

            <div class="mb-2">
                <label class="form-label small">Ime на лекар</label>
                <input type="text" id="filterDoctorName" class="form-control form-control-sm"
                       placeholder="пр. Петров" />
            </div>

            <div class="mb-2">
                <label class="form-label small">Специјалност</label>
                <select id="filterSpecialty" class="form-select form-select-sm">
                    <option value="">-- Сите --</option>
                    @foreach (var s in Model.Specialties)
                    {
                        <option value="@s.Value">@s.Text</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label small">Датум</label>
                <input type="date" id="filterDate" class="form-control form-control-sm" />
            </div>

            <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="clearFilters()">
                Исчисти филтри
            </button>
        </div>
    </div>

    @* ─────────── Десна страна (col-md-9): Сортирање + Табела + Пагинација ─────────── *@
    <div class="col-md-9">

        @* Контроли за сортирање, поставени над табелата *@
        <div class="d-flex justify-content-end align-items-center mb-2 gap-2">
            <label class="form-label small mb-0">Подреди по:</label>
            <select id="sortBy" class="form-select form-select-sm w-auto">
                <option value="Date">Датум</option>
                <option value="Time">Време</option>
                <option value="Patient">Пациент</option>
                <option value="Doctor">Лекар</option>
                <option value="Status">Статус</option>
            </select>
            <button type="button" id="sortDirectionBtn" class="btn btn-outline-secondary btn-sm"
                    onclick="toggleSortDirection()" title="Смени насока на сортирање">
                ↑ Растечки
            </button>
        </div>

        @* Контејнер каде AJAX ја вчитува табелата со термини (постоечкиот Partial View) *@
        <div id="tableContainer">
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2">Се вчитува...</p>
            </div>
        </div>

        @* Контејнер за пагинација - под табелата *@
        <div id="paginationContainer"></div>
    </div>
</div>

@* Модал за креирање и измена на термин *@
<div class="modal fade" id="appointmentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="appointmentModalTitle">Нов термин</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="appointmentForm">
                    @* Безбедносен токен за заштита од CSRF напади *@
                    @Html.AntiForgeryToken()
                    @* Скриено поле за ID - 0 значи нов термин, поинаку е измена *@
                    <input type="hidden" id="appointmentId" name="Id" value="0" />

                    <div class="row">
                        @* Dropdown за избор на лекар - се полни преку AJAX *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Лекар <span class="text-danger">*</span></label>
                            <select class="form-select" id="doctorId" name="DoctorId" required>
                                <option value="">-- Избери лекар --</option>
                            </select>
                        </div>
                        @* Dropdown за избор на пациент - се полни преку AJAX *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Пациент <span class="text-danger">*</span></label>
                            <select class="form-select" id="patientId" name="PatientId" required>
                                <option value="">-- Избери пациент --</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        @* Датум на термин - не смее да биде во минатото *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Датум <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="appointmentDate"
                                   name="AppointmentDate" required />
                        </div>
                        @* Време на термин *@
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Време <span class="text-danger">*</span></label>
                            <input type="time" class="form-control" id="appointmentTime"
                                   name="AppointmentTime" required />
                        </div>
                    </div>
                    @* Статус на термин - се полни преку AJAX *@
                    <div class="mb-3">
                        <label class="form-label">Статус</label>
                        <select class="form-select" id="status" name="Status"></select>
                    </div>
                    @* Белешки за терминот *@
                    <div class="mb-3">
                        <label class="form-label">Белешки</label>
                        <textarea class="form-control" id="notes" name="Notes" rows="2"></textarea>
                    </div>
                    @* Порака за грешка - скриена по default, се прикажува при валидациска грешка *@
                    <div id="appointmentFormErrors" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-primary" onclick="saveAppointment()">Зачувај</button>
            </div>
        </div>
    </div>
</div>

@* Модал за потврда на бришење *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Избриши термин</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Дали сте сигурни дека сакате да го избришете овој термин?</p>
                <form id="deleteForm">
                    @* Безбедносен токен *@
                    @Html.AntiForgeryToken()
                    @* ID на терминот кој се брише *@
                    <input type="hidden" id="deleteAppointmentId" value="0" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Избриши</button>
            </div>
        </div>
    </div>
</div>

@* Модал за завршување на преглед - внесување белешки (Task 9) *@
<div class="modal fade" id="finishModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title">Заврши преглед</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Внесете белешка за завршениот преглед (незадолжително):</p>
                <form id="finishForm">
                    @* Безбедносен токен *@
                    @Html.AntiForgeryToken()
                    @* ID на терминот кој се завршува *@
                    <input type="hidden" id="finishAppointmentId" value="0" />
                    <div class="mb-3">
                        <label class="form-label">Белешки</label>
                        <textarea class="form-control" id="finishNotes" rows="3"
                                  placeholder="Опис на прегледот, наод, препораки..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Откажи</button>
                <button type="button" class="btn btn-primary" onclick="confirmFinishExam()">Заврши преглед</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Иницијализација на Bootstrap модали
    const appointmentModal = new bootstrap.Modal(document.getElementById('appointmentModal'));
    const deleteModal      = new bootstrap.Modal(document.getElementById('deleteModal'));
    const finishModal      = new bootstrap.Modal(document.getElementById('finishModal'));

    // Глобална променлива за чување на dropdown податоци (лекари, пациенти, статуси) - за модалот
    let dropdowns = { doctors: [], patients: [], statuses: [] };

    // Глобална состојба на dashboard-от: тековна страница и насока на сортирање.
    // Филтрите и колоната за сортирање се читаат директно од полињата при секој повик.
    let currentPage      = 1;
    let sortDirection     = 'asc';

    // ── Читање на тековните вредности на филтрите од полињата ──────────
    function getFilterParams() {
        return {
            PatientFirstName: $('#filterPatientFirstName').val(),
            PatientLastName:  $('#filterPatientLastName').val(),
            PatientEmbg:      $('#filterPatientEmbg').val(),
            DoctorName:       $('#filterDoctorName').val(),
            Specialty:        $('#filterSpecialty').val(),
            Date:             $('#filterDate').val(),
            SortBy:           $('#sortBy').val(),
            SortDirection:    sortDirection,
            Page:             currentPage
        };
    }

    // ── Вчитување на табелата преку AJAX (постоечкиот Partial View _AppointmentsTable) ──
    function loadTable() {
        const params = getFilterParams();

        $('#tableContainer').html(`
            <div class="text-center py-4">
                <div class="spinner-border text-primary"></div>
                <p class="mt-2">Се вчитува...</p>
            </div>`);

        $.get('/Appointments/LoadTable', params, function(html) {
            $('#tableContainer').html(html);
        });
    }

    // ── Вчитување на пагинацијата преку AJAX ────────────────────────────
    function loadPagination() {
        const params = getFilterParams();
        $.get('/Appointments/LoadPagination', params, function(html) {
            $('#paginationContainer').html(html);
        });
    }

    // ── Вчитување на статистиката преку AJAX ────────────────────────────
    function loadStatistics() {
        const params = getFilterParams();
        $.get('/Appointments/LoadStatistics', params, function(html) {
            $('#statsContainer').html(html);
        });
    }

    // ── Комбинирано освежување: табела + пагинација + статистика ───────
    // Се повикува при промена на филтри или сортирање (сите три треба да се синхронизирани)
    function refreshAll() {
        loadTable();
        loadPagination();
        loadStatistics();
    }

    // ── Комбинирано освежување само на табела + пагинација ──────────────
    // Се повикува при промена на страница - статистиката не зависи од страницата
    function refreshTableOnly() {
        loadTable();
        loadPagination();
    }

    // ── Смена на страница преку копчињата Претходна/Следна ──────────────
    function goToPage(page) {
        if (page < 1) return;
        currentPage = page;
        refreshTableOnly();
    }

    // ── При промена на филтер - врати се на страница 1 и освежи сè ──────
    function onFilterChanged() {
        currentPage = 1;
        refreshAll();
    }

    // Едноставен debounce за текстуалните полиња - чека 400ms по последното копче
    // за да не се прати барање на секој внесен карактер
    let debounceTimer;
    function debouncedFilterChange() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(onFilterChanged, 400);
    }

    // Текстуални филтри - debounce на 'input' настан (додека се пишува)
    $('#filterPatientFirstName, #filterPatientLastName, #filterPatientEmbg, #filterDoctorName')
        .on('input', debouncedFilterChange);

    // Dropdown и датум филтри - веднаш при промена ('change' настан)
    $('#filterSpecialty, #filterDate').on('change', onFilterChanged);

    // ── Исчисти ги сите филтри и освежи ──────────────────────────────────
    function clearFilters() {
        $('#filterPatientFirstName, #filterPatientLastName, #filterPatientEmbg, #filterDoctorName').val('');
        $('#filterSpecialty').val('');
        $('#filterDate').val('');
        onFilterChanged();
    }

    // ── Сортирање ─────────────────────────────────────────────────────
    // При промена на колоната за сортирање - врати се на страница 1
    $('#sortBy').on('change', function() {
        currentPage = 1;
        refreshTableOnly();
    });

    // Копче за смена на насока (растечки/опаѓачки)
    function toggleSortDirection() {
        sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
        const btn = document.getElementById('sortDirectionBtn');
        btn.textContent = sortDirection === 'asc' ? '↑ Растечки' : '↓ Опаѓачки';
        currentPage = 1;
        refreshTableOnly();
    }

    // ── При вчитување на страницата ──────────────────────────────────────
    $(document).ready(function() {
        // Вчитај ги лекарите, пациентите и статусите за употреба во Create/Edit модалот
        $.get('/Appointments/GetDropdowns', function(data) {
            dropdowns = data;
        });
        // Прикажи ги термините, статистиката и пагинацијата при прво отворање
        refreshAll();
    });

    // ── Полнење на dropdown-ите во Create/Edit модалот ──────────────────
    function fillDropdowns(selectedDoctorId, selectedPatientId, selectedStatus) {
        const doctorSel  = document.getElementById('doctorId');
        const patientSel = document.getElementById('patientId');
        const statusSel  = document.getElementById('status');

        doctorSel.innerHTML  = '<option value="">-- Избери лекар --</option>';
        patientSel.innerHTML = '<option value="">-- Избери пациент --</option>';
        statusSel.innerHTML  = '';

        dropdowns.doctors.forEach(d => {
            doctorSel.appendChild(new Option(d.name, d.id, false, d.id == selectedDoctorId));
        });
        dropdowns.patients.forEach(p => {
            patientSel.appendChild(new Option(p.name, p.id, false, p.id == selectedPatientId));
        });
        dropdowns.statuses.forEach(s => {
            statusSel.appendChild(new Option(s, s, false, s === selectedStatus));
        });
    }

    // ── Отвори модал за креирање нов термин ──────────────────────────────
    function openCreateModal() {
        document.getElementById('appointmentModalTitle').textContent = 'Нов термин';
        document.getElementById('appointmentId').value   = '0';
        document.getElementById('appointmentDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('appointmentTime').value = '';
        document.getElementById('notes').value           = '';
        clearAppointmentValidation();
        fillDropdowns(0, 0, dropdowns.statuses?.[0]);
        appointmentModal.show();
    }

    // ── Отвори модал за измена на постоечки термин ───────────────────────
    function openEditModal(id) {
        $.get(`/Appointments/GetById/${id}`, function(a) {
            document.getElementById('appointmentModalTitle').textContent = 'Измени термин';
            document.getElementById('appointmentId').value   = a.id;
            document.getElementById('appointmentDate').value = a.appointmentDate?.split('T')[0];
            document.getElementById('appointmentTime').value = a.appointmentTime?.substring(0, 5);
            document.getElementById('notes').value           = a.notes || '';
            clearAppointmentValidation();
            fillDropdowns(a.doctorId, a.patientId, a.status);
            appointmentModal.show();
        });
    }

    // ── Клиентска валидација на формата за термин ────────────────────────
    function validateAppointmentForm() {
        let isValid = true;

        const doctorId = document.getElementById('doctorId');
        if (!doctorId.value) { doctorId.classList.add('is-invalid'); isValid = false; }
        else { doctorId.classList.remove('is-invalid'); doctorId.classList.add('is-valid'); }

        const patientId = document.getElementById('patientId');
        if (!patientId.value) { patientId.classList.add('is-invalid'); isValid = false; }
        else { patientId.classList.remove('is-invalid'); patientId.classList.add('is-valid'); }

        const appointmentDate = document.getElementById('appointmentDate');
        if (!appointmentDate.value) { appointmentDate.classList.add('is-invalid'); isValid = false; }
        else { appointmentDate.classList.remove('is-invalid'); appointmentDate.classList.add('is-valid'); }

        const appointmentTime = document.getElementById('appointmentTime');
        if (!appointmentTime.value) { appointmentTime.classList.add('is-invalid'); isValid = false; }
        else { appointmentTime.classList.remove('is-invalid'); appointmentTime.classList.add('is-valid'); }

        return isValid;
    }

    function clearAppointmentValidation() {
        document.getElementById('appointmentFormErrors').classList.add('d-none');
        ['doctorId', 'patientId', 'appointmentDate', 'appointmentTime'].forEach(id => {
            document.getElementById(id).classList.remove('is-invalid', 'is-valid');
        });
    }

    // ── Зачувај термин - Create или Edit зависно од ID ───────────────────
    function saveAppointment() {
        if (!validateAppointmentForm()) return;

        const id    = document.getElementById('appointmentId').value;
        const url   = id === '0' ? '/Appointments/Create' : '/Appointments/Edit';
        const token = document.querySelector('#appointmentForm input[name="__RequestVerificationToken"]').value;

        const selectedDate = new Date(document.getElementById('appointmentDate').value);
        const today = new Date(); today.setHours(0, 0, 0, 0);
        if (selectedDate < today) {
            showError('Не може да се закаже термин за минат датум.');
            return;
        }

        const data = {
            Id:              id,
            DoctorId:        document.getElementById('doctorId').value,
            PatientId:       document.getElementById('patientId').value,
            AppointmentDate: document.getElementById('appointmentDate').value,
            AppointmentTime: document.getElementById('appointmentTime').value,
            Status:          document.getElementById('status').value,
            Notes:           document.getElementById('notes').value,
            __RequestVerificationToken: token
        };

        $.post(url, data)
            .done(function() {
                appointmentModal.hide();
                refreshAll(); // Ново/изменето значи и статистиката се менува
            })
            .fail(function(xhr) {
                const response = xhr.responseJSON;
                showError(response?.errors?.join('<br>') || 'Грешка при зачувување.');
            });
    }

    function showError(msg) {
        const errDiv = document.getElementById('appointmentFormErrors');
        errDiv.innerHTML = msg;
        errDiv.classList.remove('d-none');
    }

    // ── Бришење термин ────────────────────────────────────────────────
    function deleteAppointment(id) {
        document.getElementById('deleteAppointmentId').value = id;
        deleteModal.show();
    }

    function confirmDelete() {
        const id    = document.getElementById('deleteAppointmentId').value;
        const token = document.querySelector('#deleteForm input[name="__RequestVerificationToken"]').value;

        $.post('/Appointments/Delete', { id: id, __RequestVerificationToken: token })
            .done(function() {
                deleteModal.hide();
                refreshAll(); // Бришење влијае на статистиката
            })
            .fail(function() {
                alert('Грешка при бришење.');
            });
    }

    // ── Task 8: Почеток на преглед ────────────────────────────────────
    function startExam(id) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        $.post('/Appointments/StartExam', { id: id, __RequestVerificationToken: token })
            .done(function() {
                refreshAll(); // Статусот се менува - статистиката треба да се освежи
            })
            .fail(function(xhr) {
                const response = xhr.responseJSON;
                alert(response?.errors?.join('\n') || 'Грешка при започнување на прегледот.');
            });
    }

    // ── Task 9: Завршување на преглед ─────────────────────────────────
    function openFinishModal(id) {
        document.getElementById('finishAppointmentId').value = id;
        document.getElementById('finishNotes').value = '';
        finishModal.show();
    }

    function confirmFinishExam() {
        const id    = document.getElementById('finishAppointmentId').value;
        const notes = document.getElementById('finishNotes').value;
        const token = document.querySelector('#finishForm input[name="__RequestVerificationToken"]').value;

        $.post('/Appointments/FinishExam', { id: id, notes: notes, __RequestVerificationToken: token })
            .done(function() {
                finishModal.hide();
                refreshAll(); // Статусот се менува - статистиката треба да се освежи
            })
            .fail(function(xhr) {
                const response = xhr.responseJSON;
                alert(response?.errors?.join('\n') || 'Грешка при завршување на прегледот.');
            });
    }
</script>
}

@* Partial View за пагинација (Previous/Next) - 10 записи по страница *@
@model PaginationInfo

@{
    // Пресметај однапред дали копчињата треба да се оневозможени (disabled)
    // За да не мешаме тернарен израз директно во HTML атрибутот
    bool isFirstPage = Model.CurrentPage <= 1;
    bool isLastPage  = Model.CurrentPage >= Model.TotalPages;
}

@if (Model.TotalCount == 0)
{
    <p class="text-muted text-center mt-3">Нема пронајдени термини.</p>
}
else
{
    <nav class="d-flex justify-content-between align-items-center mt-3">
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="goToPage(@(Model.CurrentPage - 1))" disabled="@isFirstPage">
            « Претходна
        </button>

        <span class="text-muted">
            Страна @Model.CurrentPage од @(Model.TotalPages == 0 ? 1 : Model.TotalPages)
            (@Model.TotalCount вкупно)
        </span>

        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="goToPage(@(Model.CurrentPage + 1))" disabled="@isLastPage">
            Следна »
        </button>
    </nav>
}

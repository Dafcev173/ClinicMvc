@* Partial View за статистичките карти над табелата - Task: статистика *@
@model AppointmentStatistics

<div class="card mb-3">
    <div class="card-header bg-dark text-white">
        📊 Статистика
    </div>
    <ul class="list-group list-group-flush">
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Вкупно термини
            <span class="badge bg-primary rounded-pill">@Model.Total</span>
        </li>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Закажани
            <span class="badge bg-info text-dark rounded-pill">@Model.Scheduled</span>
        </li>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Завршени
            <span class="badge bg-success rounded-pill">@Model.Completed</span>
        </li>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Откажани
            <span class="badge bg-danger rounded-pill">@Model.Cancelled</span>
        </li>
    </ul>
</div>

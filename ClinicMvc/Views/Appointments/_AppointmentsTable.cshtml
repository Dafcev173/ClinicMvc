@model IEnumerable<Appointment>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Датум</th>
            <th>Време</th>
            <th>Пациент</th>
            <th>Лекар</th>
            <th>Специјалност</th>
            <th>Статус</th>
            <th>Акции</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center text-muted">Нема термини.</td>
            </tr>
        }
        else
        {
            @foreach (var a in Model)
            {
                <tr id="appointment-row-@a.Id">
                    <td>@a.AppointmentDate.ToString("dd.MM.yyyy")</td>
                    <td>@a.AppointmentTime.ToString(@"hh\:mm")</td>
                    <td>@a.PatientName</td>
                    <td>@a.DoctorName</td>
                    <td>@a.DoctorSpecialty</td>
                    <td>
                        @{
                            var badgeClass = a.Status switch
                            {
                                "Zakazan"  => "bg-primary",
                                "Vo tek"   => "bg-success",
                                "Zavrsen"  => "bg-secondary",
                                "Otkazen"  => "bg-danger",
                                _          => "bg-light text-dark"
                            };
                        }
                        <span class="badge @badgeClass">@a.Status</span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning"
                                onclick="openEditModal(@a.Id)">Измени</button>
                        <button class="btn btn-sm btn-danger"
                                onclick="deleteAppointment(@a.Id)">Избриши</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
